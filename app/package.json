{
  "name": "benchlocal-app",
  "productName": "BenchLocal",
  "private": true,
  "version": "0.2.4",
  "description": "BenchLocal desktop app for running and managing LLM Bench Packs.",
  "author": "stevibe",
  "type": "module",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build:compile": "electron-vite build",
    "package": "electron-builder",
    "package:mac": "electron-builder --mac dmg zip",
    "package:win": "electron-builder --win nsis zip --x64",
    "package:linux": "electron-builder --linux AppImage tar.gz --x64",
    "build": "npm run build:compile",
    "pack": "npm run build:compile && npm run package",
    "build:dir": "npm run build:compile && electron-builder --dir",
    "build:mac": "npm run build:compile && npm run package:mac",
    "build:win": "npm run build:compile && npm run package:win",
    "build:linux": "npm run build:compile && npm run package:linux",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "web:dev:renderer": "vite --config vite.config.web.ts",
    "web:dev:server": "tsx watch src/server/index.ts",
    "web:dev": "concurrently \"npm run web:dev:renderer\" \"npm run web:dev:server\"",
    "web:build": "npm run build:compile && vite build --config vite.config.web.ts && esbuild src/server/index.ts --bundle --platform=node --target=node20 --format=esm --packages=external --outfile=../dist/server/index.mjs --external:@benchlocal/*",
    "preweb:start": "npm run web:build",
    "web:start": "node ../dist/server/index.mjs"
  },
  "dependencies": {
    "electron-updater": "^6.6.2",
    "lucide-react": "^1.7.0",
    "@benchlocal/benchpack-host": "file:../packages/benchpack-host",
    "@benchlocal/core": "file:../packages/benchlocal-core",
    "@fastify/static": "^8.0.0",
    "fastify": "^5.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.11",
    "@types/node": "^24.0.10",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^4.4.1",
    "autoprefixer": "^10.4.20",
    "electron": "37.2.0",
    "electron-builder": "^26.0.12",
    "electron-vite": "^3.1.0",
    "postcss": "^8.5.1",
    "tailwindcss": "^4.1.11",
    "typescript": "^5.8.3",
    "concurrently": "^9.0.0",
    "esbuild": "^0.25.0",
    "tsx": "^4.0.0",
    "vite": "^6.3.5"
  },
  "build": {
    "appId": "com.stevibe.benchlocal",
    "productName": "BenchLocal",
    "electronVersion": "37.2.0",
    "electronUpdaterCompatibility": ">=2.16",
    "directories": {
      "output": "dist"
    },
    "publish": {
      "provider": "github",
      "owner": "stevibe",
      "repo": "BenchLocal",
      "tagNamePrefix": "v"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../LICENSE",
        "to": "LICENSE"
      },
      {
        "from": "../packages/benchlocal-sdk",
        "to": "benchlocal-runtime/packages/benchlocal-sdk",
        "filter": [
          "dist/**/*",
          "package.json"
        ]
      },
      {
        "from": "../packages/benchlocal-core",
        "to": "benchlocal-runtime/packages/benchlocal-core",
        "filter": [
          "dist/**/*",
          "package.json"
        ]
      },
      {
        "from": "../node_modules/zod",
        "to": "benchlocal-runtime/node_modules/zod"
      },
      {
        "from": "../node_modules/smol-toml",
        "to": "benchlocal-runtime/node_modules/smol-toml"
      },
      {
        "from": "../themes",
        "to": "themes",
        "filter": [
          "*.json"
        ]
      }
    ],
    "mac": {
      "icon": "build/icon.icns",
      "category": "public.app-category.developer-tools",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "type": "distribution",
      "notarize": true,
      "target": [
        "dmg",
        "zip"
      ],
      "artifactName": "${productName}-${version}-apple-silicon.${ext}"
    },
    "dmg": {
      "sign": false
    },
    "win": {
      "target": [
        "nsis",
        "zip"
      ],
      "artifactName": "${productName}-${version}-windows-x64.${ext}"
    },
    "linux": {
      "icon": "assets/benchlocal-icon.png",
      "category": "Development",
      "target": [
        "AppImage",
        "tar.gz"
      ],
      "artifactName": "${productName}-${version}-linux-x64.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
